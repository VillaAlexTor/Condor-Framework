# ── CONDOR-REPORT BACKEND ────────────────────────────────

# Puerto del servidor Express
PORT=3001

# URL(s) del frontend permitidas por CORS (separadas por coma)
FRONTEND_URL=http://localhost:5174,http://localhost:5173

# Directorio donde se guardan los PDFs generados
OUTPUT_DIR=./output

# Timeout en ms para Puppeteer al generar PDFs
PDF_TIMEOUT=30000
