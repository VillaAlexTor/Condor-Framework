# ╔══════════════════════════════════════════════════════╗
# ║      CÓNDOR FRAMEWORK — condor-cli/.env.example      ║
# ╚══════════════════════════════════════════════════════╝
#
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Completar los valores reales en .env
#   3. NUNCA subir .env a GitHub — ya está en .gitignore
#
# Los módulos que no tengan API key configurada
# retornarán status: "skipped" sin romper el escaneo.
# Los módulos sin API key (dns, whois, wayback, crt)
# funcionan sin configuración adicional.
# ────────────────────────────────────────────────────────


# ── CENSYS ──────────────────────────────────────────────
# Registro gratuito: https://accounts.censys.io/register
# Plan free: 250 queries/mes
# Obtener keys en: https://search.censys.io/account/api
#
CENSYS_API_ID=
CENSYS_API_SECRET=


# ── SHODAN ───────────────────────────────────────────────
# Registro gratuito: https://account.shodan.io/register
# Plan free: 1 query credit, sin búsqueda histórica
# Plan académico gratuito: https://developer.shodan.io/api/requirements
# Obtener key en: https://account.shodan.io
#
SHODAN_API_KEY=


# ── HUNTER.IO ────────────────────────────────────────────
# Registro gratuito: https://hunter.io/users/sign_up
# Plan free: 25 búsquedas/mes
# Obtener key en: https://hunter.io/api-keys
#
HUNTER_API_KEY=


# ── HAVE I BEEN PWNED (opcional — módulo futuro) ─────────
# Registro: https://haveibeenpwned.com/API/Key
# Verifica si emails del dominio aparecen en brechas
# Plan: USD 3.50/mes (no tiene tier gratuito desde 2019)
#
HIBP_API_KEY=


# ── CONFIGURACIÓN GENERAL ────────────────────────────────
# Timeout por defecto para consultas de red (segundos)
# Se puede sobreescribir con --timeout N en el CLI
#
CONDOR_TIMEOUT=10

# Directorio de output por defecto
# Si no se especifica --output, los archivos se guardan aquí
#
CONDOR_OUTPUT_DIR=./output
